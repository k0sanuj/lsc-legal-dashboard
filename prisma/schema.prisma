generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Entity {
  LSC
  TBR
  FSP
  XTZ
  XTE
}

enum LifecycleStatus {
  DRAFT
  IN_REVIEW
  NEGOTIATION
  AWAITING_SIGNATURE
  SIGNED
  ACTIVE
  EXPIRING
  EXPIRED
  TERMINATED
}

enum DocumentCategory {
  SPONSORSHIP
  VENDOR
  EMPLOYMENT
  ESOP
  NDA
  ARENA_HOST
  TERMS_OF_SERVICE
  WAIVER
  IP_ASSIGNMENT
  PILOT_PROGRAM
  BOARD_RESOLUTION
  POLICY
  OTHER
  // New expanded categories
  MSA
  SLA
  CONTRACTOR
  REFERRAL_PARTNER
  VENUE
  PRODUCTION_PARTNER
  CLICKWRAP
  REGISTERED_OFFICE
  SAAS_SUBSCRIPTION
  INSURANCE
  GOVERNMENT_FILING
  LITIGATION_DOC
  SUBSIDY_GRANT
}

enum SignatureStatus {
  PENDING
  SENT
  SIGNED
  STALLED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IssueCategory {
  IP
  EMPLOYMENT
  REGULATORY
  CONTRACTUAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
}

enum TrackerCategory {
  PLATFORM
  VAUNT_ACQUISITION
  KEY_AGREEMENTS
  CORPORATE
  PAYMENTS
  IP_PATENTS
  GIG_MARKETING
  OTHER
}

enum TrackerStatus {
  NOT_STARTED
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  COMPLETE
}

enum VestingType {
  STANDARD_4Y_1Y_CLIFF
  GRADED
  MILESTONE
  CUSTOM
}

enum VestingEventStatus {
  PENDING
  VESTED
  FORFEITED
}

enum PaymentTerms {
  NET_30
  NET_60
  MILESTONE
  CUSTOM
}

enum PaymentCycleStatus {
  UPCOMING
  ACTIVE
  OVERDUE
  COMPLETED
}

enum ComplianceStatus {
  UPCOMING
  DUE_SOON
  OVERDUE
  COMPLETED
}

enum Jurisdiction {
  UAE
  US_DELAWARE
  GLOBAL
  INDIA
  KENYA
  UK
  SINGAPORE
  CAYMAN
}

enum UserRole {
  PLATFORM_ADMIN
  FINANCE_ADMIN
  LEGAL_ADMIN
  OPS_ADMIN
  FSP_FINANCE
  COMMERCIAL_OFFICER
  TEAM_MEMBER
  EXTERNAL_AUDITOR
}

enum NoticeCategory {
  DATA_PROTECTION
  COMPLAINT
  LEGAL_NOTICE
  REGULATORY
  OTHER
}

enum NoticeStatus {
  NEW
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
}

enum RegistrationStatus {
  ACTIVE
  PENDING
  EXPIRED
  AT_RISK
}

enum LitigationStatus {
  PRE_FILING
  FILED
  DISCOVERY
  TRIAL
  APPEAL
  SETTLED
  CLOSED
}

enum SubsidyStatus {
  IDENTIFIED
  APPLYING
  APPROVED
  REJECTED
  DISBURSED
}

enum KycDocStatus {
  COLLECTED
  VERIFIED
  EXPIRED
  NEEDS_RENEWAL
}

enum EmailTag {
  INVOICE
  LEGAL_NOTICE
  AGREEMENT
  CORRESPONDENCE
  MARKETING
  INTERNAL
}

enum AgentPriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model AppUser {
  id            String   @id @default(uuid())
  full_name     String
  email         String   @unique
  role          UserRole
  password_hash String
  is_active     Boolean  @default(true)
  last_login_at DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  access_events     AuthAccessEvent[]
  owned_documents   LegalDocument[]    @relation("DocumentOwner")
  reported_issues   LegalIssue[]       @relation("IssueReporter")
  assigned_issues   LegalIssue[]       @relation("IssueAssignee")
  acknowledgments   PolicyAcknowledgment[]
  document_notes    DocumentNote[]     @relation("NoteAuthor")
  document_comments DocumentComment[]  @relation("CommentAuthor")
  notifications     Notification[]
  assigned_notices  IncomingNotice[]   @relation("NoticeAssignee")
  compliance_officer_for ComplianceOfficer[]
  assigned_litigation    LitigationCase[] @relation("LitigationAssignee")
  assigned_kyc           KycDocument[]    @relation("KycAssignee")
}

model AuthAccessEvent {
  id           String   @id @default(uuid())
  app_user_id  String
  event_type   String
  event_status String
  ip_address   String?
  user_agent   String?
  metadata     Json?
  created_at   DateTime @default(now())

  user AppUser @relation(fields: [app_user_id], references: [id])

  @@index([app_user_id, created_at])
}

// ─── Legal Document Core ─────────────────────────────────────────────────────

model LegalDocument {
  id               String           @id @default(uuid())
  title            String
  category         DocumentCategory
  lifecycle_status LifecycleStatus  @default(DRAFT)
  parties          Json?
  value            Decimal?
  currency         String           @default("AED")
  entity           Entity
  sport            String?
  owner_id         String
  expiry_date      DateTime?
  parent_doc_id    String?
  signatories      Json?
  notes            String?
  file_url         String?
  finance_sponsor_id String?
  counterparty     String?
  assigned_to      String?
  financial_impact_recurring Decimal?
  financial_impact_onetime   Decimal?
  auto_renew       Boolean          @default(false)
  hellosign_envelope_id String?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  owner              AppUser            @relation("DocumentOwner", fields: [owner_id], references: [id])
  parent             LegalDocument?     @relation("DocumentAddenda", fields: [parent_doc_id], references: [id])
  addenda            LegalDocument[]    @relation("DocumentAddenda")
  versions           DocumentVersion[]
  lifecycle_events   LifecycleEvent[]
  signature_requests SignatureRequest[]
  payment_cycles     PaymentCycle[]
  email_threads      EmailThread[]
  audit_documents    AuditDocument[]    @relation("DocumentAuditDocs")
  notes_entries      DocumentNote[]
  comments           DocumentComment[]

  @@index([entity, lifecycle_status])
  @@index([expiry_date])
  @@index([owner_id])
  @@index([category])
}

model DocumentVersion {
  id              String   @id @default(uuid())
  document_id     String
  version_number  Int
  file_url        String?
  change_summary  String?
  created_by      String
  created_at      DateTime @default(now())

  document LegalDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id, version_number])
}

model LifecycleEvent {
  id              String          @id @default(uuid())
  document_id     String
  from_status     LifecycleStatus
  to_status       LifecycleStatus
  transitioned_by String
  notes           String?
  created_at      DateTime        @default(now())

  document LegalDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id, created_at])
}

// ─── Signatures ──────────────────────────────────────────────────────────────

model SignatureRequest {
  id              String          @id @default(uuid())
  document_id     String
  signatory_name  String
  signatory_email String
  status          SignatureStatus @default(PENDING)
  sent_at         DateTime?
  signed_at       DateTime?
  reminder_count  Int             @default(0)
  stalled_reason  String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  document LegalDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id, status])
  @@index([status])
}

// ─── Templates ───────────────────────────────────────────────────────────────

model ContractTemplate {
  id          String           @id @default(uuid())
  name        String
  category    DocumentCategory
  entity      Entity?
  sport       String?
  content     String
  variables   Json
  version     Int              @default(1)
  usage_count Int              @default(0)
  is_active   Boolean          @default(true)
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
}

// ─── Compliance ──────────────────────────────────────────────────────────────

model ComplianceDeadline {
  id                 String           @id @default(uuid())
  title              String
  description        String?
  jurisdiction       Jurisdiction
  category           String
  deadline_date      DateTime
  recurring          Boolean          @default(false)
  recurrence_rule    String?
  status             ComplianceStatus @default(UPCOMING)
  linked_document_id String?
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@index([deadline_date, status])
  @@index([jurisdiction])
}

model ComplianceRecord {
  id                    String             @id @default(uuid())
  entity                Entity
  sport                 String?
  jurisdiction          Jurisdiction
  check_type            String
  status                RegistrationStatus @default(PENDING)
  registration_number   String?
  registration_details  String?
  last_checked          DateTime?
  next_check            DateTime?
  notes                 String?
  assigned_to           String?
  cost_monthly          Decimal?
  cost_annual           Decimal?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt

  @@unique([entity, jurisdiction, check_type])
  @@index([entity, jurisdiction])
  @@index([status])
}

model ComplianceOfficer {
  id          String   @id @default(uuid())
  entity      Entity
  sport       String?
  user_id     String
  is_primary  Boolean  @default(false)
  created_at  DateTime @default(now())

  user AppUser @relation(fields: [user_id], references: [id])

  @@unique([entity, user_id])
  @@index([entity])
}

model RegisteredOfficeAgreement {
  id              String   @id @default(uuid())
  entity          Entity
  sport           String?
  jurisdiction    Jurisdiction
  address         String
  landlord        String?
  document_url    String?
  renewal_date    DateTime
  cost_annual     Decimal?
  currency        String   @default("AED")
  auto_renew      Boolean  @default(false)
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([entity, renewal_date])
}

model CompanyEmail {
  id              String   @id @default(uuid())
  entity          Entity
  sport           String?
  email_address   String   @unique
  owner_name      String?
  last_activity   DateTime?
  status          String   @default("active")
  domain          String
  domain_expiry   DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([entity])
  @@index([status])
}

model DataProtectionRecord {
  id                     String       @id @default(uuid())
  entity                 Entity
  sport                  String?
  jurisdiction           Jurisdiction
  applicable_law         String
  dpo_required           Boolean      @default(false)
  dpo_name               String?
  dpo_email              String?
  registration_status    String?
  registration_authority String?
  last_audit_date        DateTime?
  privacy_policy_url     String?
  dpa_in_place           Boolean      @default(false)
  breach_procedure       Boolean      @default(false)
  health_score           Int?
  notes                  String?
  created_at             DateTime     @default(now())
  updated_at             DateTime     @updatedAt

  @@unique([entity, jurisdiction])
  @@index([entity])
}

// ─── ESOP & Equity ───────────────────────────────────────────────────────────

model ESOPGrant {
  id                 String      @id @default(uuid())
  employee_name      String
  employee_email     String?
  entity             Entity      @default(LSC)
  sport              String?
  grant_date         DateTime
  total_shares       Int
  vested_shares      Int         @default(0)
  exercise_price     Decimal
  vesting_type       VestingType
  cliff_months       Int         @default(12)
  vesting_months     Int         @default(48)
  clawback_triggers  Json?
  acceleration_events Json?
  jp_split_ratio     Decimal?
  legal_document_id  String?

  // Finance integration
  holder_type         String? // "founder" | "employee" | "investor" | "advisor"
  share_class         String? // "common" | "preferred_a" | "preferred_b" | "options"
  vesting_start_date  DateTime? @db.Date
  vesting_end_date    DateTime? @db.Date
  agreement_reference String?

  // Sync tracking
  last_finance_post_at    DateTime?
  finance_post_status     String?
  last_finance_post_error String?

  created_at         DateTime    @default(now())
  updated_at         DateTime    @updatedAt

  vesting_events VestingEvent[]

  @@index([finance_post_status])
}

model VestingEvent {
  id              String             @id @default(uuid())
  grant_id        String
  vest_date       DateTime
  shares_vesting  Int
  status          VestingEventStatus @default(PENDING)
  created_at      DateTime           @default(now())

  grant ESOPGrant @relation(fields: [grant_id], references: [id], onDelete: Cascade)

  @@index([grant_id, vest_date])
}

// ─── Policies ────────────────────────────────────────────────────────────────

model PolicyDocument {
  id                     String   @id @default(uuid())
  title                  String
  version                Int      @default(1)
  effective_date         DateTime
  category               String
  content                String?
  file_url               String?
  acknowledgment_required Boolean @default(true)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  acknowledgments PolicyAcknowledgment[]
}

model PolicyAcknowledgment {
  id              String   @id @default(uuid())
  policy_id       String
  user_id         String
  acknowledged_at DateTime @default(now())

  policy PolicyDocument @relation(fields: [policy_id], references: [id], onDelete: Cascade)
  user   AppUser        @relation(fields: [user_id], references: [id])

  @@unique([policy_id, user_id])
}

// ─── Issues ──────────────────────────────────────────────────────────────────

model LegalIssue {
  id               String        @id @default(uuid())
  title            String
  description      String
  category         IssueCategory
  reporter_id      String
  assigned_to      String?
  priority         Priority
  sla_deadline     DateTime
  status           IssueStatus   @default(OPEN)
  resolution       String?
  escalation_level Int           @default(0)
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  reporter AppUser  @relation("IssueReporter", fields: [reporter_id], references: [id])
  assignee AppUser? @relation("IssueAssignee", fields: [assigned_to], references: [id])

  @@index([status, sla_deadline])
  @@index([category, priority])
}

// ─── Tracker ─────────────────────────────────────────────────────────────────

model TrackerItem {
  id              String          @id @default(uuid())
  ref_code        String          @unique
  title           String
  category        TrackerCategory
  priority        Priority
  status          TrackerStatus   @default(NOT_STARTED)
  assigned_to     String?
  dependency_refs String[]
  due_date        DateTime?
  notes           String?
  blocking_notes  String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  @@index([category, priority])
  @@index([status])
}

// ─── Payment Cycles ──────────────────────────────────────────────────────────

model PaymentCycle {
  id              String             @id @default(uuid())
  document_id     String
  terms           PaymentTerms
  custom_terms    String?
  amount          Decimal
  currency        String             @default("AED")
  cycle_start     DateTime?
  cycle_end       DateTime?
  status          PaymentCycleStatus @default(UPCOMING)
  finance_sync_id String?
  last_sync_at    DateTime?

  // Finance integration: tranche metadata
  tranche_number       Int?
  tranche_label        String?
  tranche_percentage   Decimal? @db.Decimal(5, 2)
  tranche_amount_usd   Decimal? @db.Decimal(14, 2)
  trigger_type         String? // "on_signing" | "pre_event" | "post_event" | "on_milestone" | "on_date"
  trigger_date         DateTime? @db.Date
  trigger_offset_days  Int?     @default(0)
  contract_name        String? // denormalized so Finance can resolve via (companyCode, contractName)
  notes                String?

  // Sync tracking
  last_finance_post_at    DateTime?
  finance_post_status     String? // "synced" | "pending" | "failed"
  last_finance_post_error String?

  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt

  document LegalDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
  @@index([status])
  @@index([finance_post_status])
}

// ─── KYC & Administrator Accounts ────────────────────────────────────────────

model KycDocument {
  id            String       @id @default(uuid())
  entity        Entity
  sport         String?
  jurisdiction  Jurisdiction
  document_type String
  document_name String
  file_url      String?
  status        KycDocStatus @default(COLLECTED)
  expiry_date   DateTime?
  verified_by   String?
  verified_at   DateTime?
  notes         String?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  verifier AppUser? @relation("KycAssignee", fields: [verified_by], references: [id])

  @@index([entity, jurisdiction])
  @@index([status])
  @@index([expiry_date])
}

model AdminAccount {
  id                   String   @id @default(uuid())
  entity               Entity
  sport                String?
  platform_name        String
  platform_url         String?
  account_holder       String
  access_level         String
  last_verified        DateTime?
  two_factor_enabled   Boolean  @default(false)
  recovery_documented  Boolean  @default(false)
  notes                String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([entity])
}

// ─── Litigation ──────────────────────────────────────────────────────────────

model LitigationCase {
  id                    String           @id @default(uuid())
  case_name             String
  case_number           String?
  jurisdiction          Jurisdiction
  court_tribunal        String?
  entity                Entity
  sport                 String?
  plaintiff             String
  defendant             String
  third_parties         Json?
  status                LitigationStatus @default(PRE_FILING)
  filing_date           DateTime?
  next_hearing          DateTime?
  statute_of_limitations DateTime?
  assigned_counsel      String?
  external_counsel      String?
  estimated_liability   Decimal?
  legal_fees_to_date    Decimal?
  projected_total_cost  Decimal?
  currency              String           @default("AED")
  notes                 String?
  assigned_to           String?
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt

  assignee AppUser?          @relation("LitigationAssignee", fields: [assigned_to], references: [id])
  events   LitigationEvent[]
  documents LitigationDocument[]

  @@index([entity, status])
  @@index([next_hearing])
}

model LitigationEvent {
  id          String   @id @default(uuid())
  case_id     String
  event_type  String
  title       String
  description String?
  event_date  DateTime
  created_by  String?
  created_at  DateTime @default(now())

  case_record LitigationCase @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id, event_date])
}

model LitigationDocument {
  id          String   @id @default(uuid())
  case_id     String
  title       String
  file_url    String?
  doc_type    String
  uploaded_by String?
  created_at  DateTime @default(now())

  case_record LitigationCase @relation(fields: [case_id], references: [id], onDelete: Cascade)

  @@index([case_id])
}

// ─── Email Intelligence ──────────────────────────────────────────────────────

model DetectedInvoice {
  id                  String   @id @default(uuid())
  vendor_name         String
  amount              Decimal
  currency            String   @default("AED")
  invoice_date        DateTime?
  entity              Entity?
  sport               String?
  category            String?
  verification_status String   @default("pending")
  math_check_passed   Boolean  @default(false)
  original_email_id   String?
  file_url            String?
  routed_to_finance   Boolean  @default(false)
  notes               String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([entity])
  @@index([verification_status])
}

model EmailTagRecord {
  id          String   @id @default(uuid())
  email_id    String
  subject     String
  from_addr   String
  tag         EmailTag
  confidence  Float    @default(1.0)
  processed   Boolean  @default(false)
  created_at  DateTime @default(now())

  @@index([tag])
  @@index([email_id])
}

// ─── Clickwrap Agreements ────────────────────────────────────────────────────

model ClickwrapAcceptance {
  id                String   @id @default(uuid())
  person_name       String
  person_email      String
  agreement_title   String
  agreement_version Int
  accepted_at       DateTime @default(now())
  ip_address        String?
  user_agent        String?
  entity            Entity?
  sport             String?

  @@index([person_email])
  @@index([agreement_title, agreement_version])
}

// ─── Subsidies ───────────────────────────────────────────────────────────────

model Subsidy {
  id                    String        @id @default(uuid())
  title                 String
  entity                Entity
  sport                 String?
  jurisdiction          Jurisdiction
  source                String
  status                SubsidyStatus @default(IDENTIFIED)
  amount                Decimal?
  currency              String        @default("AED")
  conditions            String?
  reporting_requirements String?
  application_date      DateTime?
  approval_date         DateTime?
  disbursement_date     DateTime?
  website_url           String?
  notes                 String?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  @@index([entity, status])
}

// ─── Audit Reports ───────────────────────────────────────────────────────────

model AuditReport {
  id          String   @id @default(uuid())
  audit_type  String
  entity      Entity?
  sport       String?
  jurisdiction Jurisdiction?
  findings    Json
  summary     String?
  risk_items  Int      @default(0)
  compliant_items Int  @default(0)
  total_items Int      @default(0)
  run_by      String   @default("system")
  created_at  DateTime @default(now())

  @@index([audit_type, created_at])
  @@index([entity])
}

// ─── Agent System ────────────────────────────────────────────────────────────

model AgentActivityLog {
  id         String   @id @default(uuid())
  agent_id   String
  agent_name String
  action     String
  details    Json?
  created_at DateTime @default(now())

  @@index([agent_id, created_at])
  @@index([agent_name])
}

model AgentMessage {
  id                String        @id @default(uuid())
  from_agent        String
  to_agent          String
  intent            String
  payload           Json
  priority          AgentPriority @default(NORMAL)
  requires_response Boolean       @default(false)
  responded         Boolean       @default(false)
  response_payload  Json?
  created_at        DateTime      @default(now())

  @@index([to_agent, created_at])
  @@index([from_agent])
  @@index([intent])
}

// ─── Project Checklist ───────────────────────────────────────────────────────

model ProjectChecklist {
  id             String   @id @default(uuid())
  title          String
  done           Boolean  @default(false)
  priority       Priority @default(MEDIUM)
  category       String   @default("General")
  dependency_ids String[]
  notes          String?
  sort_order     Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([done, priority])
  @@index([category])
}

// ─── Dashboard Config ────────────────────────────────────────────────────────

model DashboardTableConfig {
  id          String   @id @default(uuid())
  table_key   String   @unique
  columns     Json
  sort_order  Json?
  filters     Json?
  locked      Boolean  @default(true)
  updated_by  String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model FileNamingLog {
  id           String   @id @default(uuid())
  original_name String
  renamed_to    String
  entity        Entity?
  sport         String?
  category      String?
  approved      Boolean  @default(false)
  approved_by   String?
  created_at    DateTime @default(now())
}

// ─── Shared / Cross-Module ───────────────────────────────────────────────────

model AuditDocument {
  id                 String   @id @default(uuid())
  file_url           String
  file_type          String
  uploaded_by        String
  uploaded_at        DateTime @default(now())
  linked_entity_type String
  linked_entity_id   String
  created_at         DateTime @default(now())

  legal_document_id String?
  legal_document    LegalDocument? @relation("DocumentAuditDocs", fields: [legal_document_id], references: [id])

  @@index([linked_entity_type, linked_entity_id])
}

model EmailThread {
  id               String   @id @default(uuid())
  subject          String
  participants     Json
  document_id      String?
  last_activity_at DateTime
  messages         Json?
  created_at       DateTime @default(now())

  document LegalDocument? @relation(fields: [document_id], references: [id])

  @@index([document_id])
}

model CalendarEvent {
  id                 String   @id @default(uuid())
  title              String
  event_type         String
  start_date         DateTime
  end_date           DateTime?
  entity             Entity?
  sport              String?
  linked_entity_type String?
  linked_entity_id   String?
  created_at         DateTime @default(now())

  @@index([start_date])
  @@index([entity])
}

model CrossModuleEvent {
  id          String   @id @default(uuid())
  source      String
  event_type  String
  entity_type String
  entity_id   String
  payload     Json
  processed   Boolean  @default(false)
  created_at  DateTime @default(now())

  @@index([source, processed])
  @@index([created_at])
}

// ─── Document Notes & Comments ───────────────────────────────────────────────

model DocumentNote {
  id          String   @id @default(uuid())
  document_id String
  content     String
  author_id   String
  created_at  DateTime @default(now())

  document LegalDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)
  author   AppUser       @relation("NoteAuthor", fields: [author_id], references: [id])

  @@index([document_id, created_at])
}

model DocumentComment {
  id          String   @id @default(uuid())
  document_id String
  content     String
  author_id   String
  resolved    Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  document LegalDocument @relation(fields: [document_id], references: [id], onDelete: Cascade)
  author   AppUser       @relation("CommentAuthor", fields: [author_id], references: [id])

  @@index([document_id, created_at])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  type       String
  title      String
  message    String
  link       String?
  read       Boolean  @default(false)
  created_at DateTime @default(now())

  user AppUser @relation(fields: [user_id], references: [id])

  @@index([user_id, read, created_at])
}

// ─── Incoming Notices (Compliance) ───────────────────────────────────────────

model IncomingNotice {
  id              String         @id @default(uuid())
  subject         String
  from_email      String?
  body            String?
  category        NoticeCategory
  received_at     DateTime       @default(now())
  response_deadline DateTime?
  status          NoticeStatus   @default(NEW)
  assigned_to     String?
  forwarded_to    Json?
  linked_issue_id String?
  jurisdiction    Jurisdiction?
  escalation_level Int           @default(0)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  assignee AppUser? @relation("NoticeAssignee", fields: [assigned_to], references: [id])

  @@index([status, received_at])
  @@index([category])
  @@index([response_deadline])
}
